# Django Settings
DEBUG=False
SECRET_KEY=generate-a-secure-key-here
ALLOWED_HOSTS=yourdomain.com

# Database Settings
DB_ENGINE=postgresql
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=127.0.0.1
DB_PORT=5432

# Turnstile API Security
# This key must be sent in the X-API-KEY header by the hardware scanner
TURNSTILE_API_KEY=generate-a-long-random-string-here
